<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body>
    <div class="header">
      <img src="/images/olympics.svg" alt="" />
      <h1><%= title %></h1>
    </div>

    <p class="primary">Welcome to <%= title %></p>

    <p><a href="/oi">Link</a> para a página oi.</p>
    <p>
      <a class="primary" href="/users">Users</a>
    </p>

    <form action="/submit" method="POST">
      <div class="form-row">
        <label for="nome">Nome: </label>
        <input type="text" id="nome" name="nome" />
      </div>
      <div class="form-row">
        <label for="altura">Altura: (cm) </label>
        <input type="number" id="altura" name="altura" />
      </div>
      <div class="form-row">
        <label for="peso">Peso: (kg) </label>
        <input type="number" id="peso" name="peso" />
      </div>
      <div class="form-row">
        <input type="submit" value="Enviar" />
      </div>
    </form>
  </body>
</html>
