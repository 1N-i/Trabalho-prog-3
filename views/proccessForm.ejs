<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sucesso - Almoxarifado Virtual</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body>
    <header>
      <h1>Almoxarifado Virtual</h1>
      <nav>
        <ul>
          <li><a href="/">Dashboard</a></li>
          <li><a href="/inventario">Inventário (Estoque)</a></li>
          <li><a href="/entrada">Entrada de Itens</a></li>
          <li><a href="/retirada">Retirada</a></li>
          <li><a href="/sobre">Sobre a Equipe</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <div
        class="card"
        style="text-align: center; max-width: 600px; margin: 0 auto"
      >
        <h2 style="color: #27ae60">Parabéns, recebemos sua resposta!</h2>
        <p>Os dados coletados pelo servidor de teste foram:</p>

        <ul
          style="
            list-style: none;
            padding: 0;
            margin-top: 20px;
            font-size: 1.1rem;
            text-align: left;
            background: #f4f7f6;
            padding: 15px;
            border-radius: 8px;
          "
        >
          <li style="margin-bottom: 10px">
            <strong>Nome:</strong> <%= nome %>
          </li>
          <li style="margin-bottom: 10px">
            <strong>Altura:</strong> <%= altura %> cm
          </li>
          <li><strong>Peso:</strong> <%= peso %> kg</li>
        </ul>

        <br />
        <a
          href="/"
          class="btn-submit"
          style="width: auto; background-color: #34495e; margin-top: 10px"
          >Voltar ao Dashboard</a
        >
      </div>
    </main>
  </body>
</html>
