<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> - Almoxarifado Virtual</title>

    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body>
    <header>
      <h1>Almoxarifado Virtual</h1>
      <nav>
        <ul>
          <li><a href="/">Dashboard</a></li>
          <li><a href="/inventario">Inventário (Estoque)</a></li>
          <li><a href="/entrada">Entrada de Itens</a></li>
          <li><a href="/retirada">Retirada</a></li>
          <li><a href="/sobre">Sobre a Equipe</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <h2><%= title %></h2>
      <p>
        Aqui você pode visualizar, buscar e gerenciar todos os itens do
        almoxarifado.
      </p>

      <div class="form-group busca-container">
        <label for="buscaItem">Pesquisar Item:</label>
        <input
          type="text"
          id="buscaItem"
          placeholder="Digite o nome do produto..."
        />
      </div>

      <table id="tabela-estoque">
        <thead>
          <tr>
            <th>Imagem</th>
            <th>Nome do Item</th>
            <th>Categoria</th>
            <th>Qtd. Atual</th>
            <th>Qtd. Mínima</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody id="corpo-tabela">
          <tr>
            <td colspan="6" class="texto-vazio">
              Nenhum item cadastrado ainda. O estoque está vazio.
            </td>
          </tr>
        </tbody>
      </table>
    </main>

    <script src="/javascripts/estoque.js"></script>
  </body>
</html>
